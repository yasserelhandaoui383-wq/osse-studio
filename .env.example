# ---- Osse Studio environment ----
DATABASE_URL="file:./dev.db"

# Local generation backend (ComfyUI running headless on your 8GB GPU)
COMFYUI_URL="http://127.0.0.1:8188"

# Where generated media is written (absolute or relative to project root)
MEDIA_DIR="./media"

# Path to ffmpeg binary (leave as "ffmpeg" if on PATH)
FFMPEG_PATH="ffmpeg"

# Optional Python orchestrator (only needed for advanced ComfyUI workflows)
ORCHESTRATOR_URL="http://127.0.0.1:8123"

# ---- Optional cloud fallback (leave blank to stay 100% local) ----
KLING_API_KEY=""
KLING_API_BASE="https://api.klingai.com"
